        {
          "name": "TC_Products_009 Sort products by price ascending",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Vaidate Response\r",
                  "pm.test(\"Validate Status Code is 200\", ()=>{\r",
                  "    pm.response.to.have.status(200)\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response should be an Array and Price is sorted Ascending\", ()=>{\r",
                  "    var jsonData=pm.response.json();\r",
                  "    pm.expect(jsonData).to.be.an('array');\r",
                  "    \r",
