  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "function randomNumber(length) {\r",
          "    let min = Math.pow(10, length - 1);\r",
          "    let max = Math.pow(10, length) - 1;\r",
          "\r",
          "    return Math.floor(min + Math.random() * (max - min + 1));\r",
          "}\r",
          "var randomString = Math.random().toString(36).substring(2, 10);\r",
          "\r",
          "var useramail =\"user\"+randomString+randomNumber(2)+\"@gmail.com\";\r",
          "var username = \"user \"+randomString;\r",
          "var usernumber=randomNumber(11);\r",
          "\r",
          "pm.variables.set(\"useremail\", useramail);\r",
          "pm.variables.set(\"username\",username);\r",
          "pm.variables.set(\"usernumber\", usernumber);"
        ]
      }
    },
